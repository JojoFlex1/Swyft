generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pool {
  id                String   @id @default(cuid())
  token0Address     String
  token1Address     String
  feeTier           Int
  currentSqrtPrice  String
  currentTick       Int
  liquidity         String
  tvl               String
  volume24h         String
  feeApr            String
  createdAt         DateTime @default(now())

  // Relations
  swaps             Swap[]
  positions         Position[]
  priceCandles      PriceCandle[]

  @@map("pool")
  @@index([token0Address, token1Address])
  @@index([createdAt])
}

model Swap {
  id                String   @id @default(cuid())
  poolId            String
  senderAddress     String
  recipientAddress  String
  amount0           String
  amount1           String
  sqrtPriceAfter    String
  tickAfter         Int
  transactionHash   String
  timestamp         DateTime @default(now())

  // Relations
  pool              Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@map("swap")
  @@index([poolId])
  @@index([senderAddress])
  @@index([timestamp])
  @@index([transactionHash])
}

model Position {
  id                String   @id @default(cuid())
  poolId            String
  ownerAddress      String
  tokenId           String   // NFT token ID
  lowerTick         Int
  upperTick         Int
  liquidity         String
  feesCollected0    String   @default("0")
  feesCollected1    String   @default("0")
  createdAt         DateTime @default(now())
  closedAt          DateTime?

  // Relations
  pool              Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@map("position")
  @@index([poolId])
  @@index([ownerAddress])
  @@index([createdAt])
  @@index([closedAt])
}

model Token {
  id                String   @id @default(cuid())
  address           String   @unique
  symbol            String
  name              String
  decimals          Int
  logoUri           String?

  @@map("token")
}

model PriceCandle {
  id                String   @id @default(cuid())
  poolId            String
  open              String
  high              String
  low               String
  close             String
  volume            String
  timestamp         DateTime
  interval          String   // '1m', '5m', '1h', '1d'

  // Relations
  pool              Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@map("price_candle")
  @@index([poolId])
  @@index([timestamp])
  @@index([interval])
}
